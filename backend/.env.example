# Cuba Libre API — Environment Variables
# Copy to .env and fill in your values

DATABASE_URL=postgresql://...              # Supabase connection string
JWT_SECRET=change-this-to-a-random-secret
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:4200,https://cuba.red

# AI
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=                        # optional fallback

# Payments (Solidarity Network)
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
AIRWALLEX_API_KEY=
AIRWALLEX_CLIENT_ID=

# File Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Frontend (used for redirect URLs)
FRONTEND_URL=https://cuba.red

# OAuth
GOOGLE_CLIENT_ID=

# Jamendo (Cuban radio discovery)
JAMENDO_CLIENT_ID=b6747d04
