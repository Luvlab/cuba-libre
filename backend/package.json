{
  "name": "cuba-libre-api",
  "version": "1.0.0",
  "description": "Open-source community API for Cuba Libre — free, for the Cuban people",
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "dev":         "nodemon --watch src --ext ts --exec 'ts-node src/index.ts'",
    "build":       "tsc && prisma generate",
    "start":       "node dist/index.js",
    "postinstall": "prisma generate",
    "db:push":     "prisma db push",
    "db:migrate":  "prisma migrate dev",
    "db:studio":   "prisma studio",
    "db:generate": "prisma generate",
    "scrape:osm":  "ts-node src/scraper/osm.ts",
    "seed":        "ts-node src/seed.ts"
  },
  "engines": { "node": "22.x" },
  "dependencies": {
    "@anthropic-ai/sdk":   "^0.91.1",
    "@prisma/adapter-pg":  "^7.8.0",
    "@prisma/client":      "^7.8.0",
    "@vercel/blob":        "^2.3.3",
    "@vercel/node":        "^5.7.13",
    "airwallex-payment-elements": "^1.0.0",
    "bcryptjs":            "^3.0.3",
    "cheerio":             "^1.2.0",
    "cors":                "^2.8.6",
    "dotenv":              "^17.4.2",
    "express":             "^5.2.1",
    "google-auth-library": "^10.6.2",
    "helmet":              "^8.1.0",
    "jsonwebtoken":        "^9.0.3",
    "morgan":              "^1.10.1",
    "pg":                  "^8.20.0",
    "prisma":              "^7.8.0",
    "rss-parser":          "^3.13.0",
    "stripe":              "^22.1.0",
    "uuid":                "^9.0.1",
    "ws":                  "^8.20.0",
    "zod":                 "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs":    "^2.4.6",
    "@types/cors":        "^2.8.19",
    "@types/express":     "^5.0.6",
    "@types/jsonwebtoken":"^9.0.10",
    "@types/morgan":      "^1.9.10",
    "@types/node":        "^25.6.0",
    "@types/pg":          "^8.20.0",
    "@types/uuid":        "^10.0.0",
    "@types/ws":          "^8.18.1",
    "nodemon":            "^3.1.14",
    "ts-node":            "^10.9.2",
    "typescript":         "^6.0.3"
  }
}
